# GitHub Personal Access Token for contribution chart
# Create one at: https://github.com/settings/tokens
# Required scopes: read:user
# Supports both classic tokens (ghp_) and fine-grained tokens (github_pat_)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Resend API Key for contact form emails
# Create one at: https://resend.com/api-keys
# Optional: If not set, contact form submissions will be logged to console
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
